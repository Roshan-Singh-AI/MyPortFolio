# ---------------------------------------------------------------------------
# Copy this file to .env.local and fill in values. NEVER commit real secrets.
# .env* is gitignored. None of these are required for the site to work --
# every feature degrades gracefully when they are absent.
# ---------------------------------------------------------------------------

# Groq API key for the "Ask my work" demo (/api/ask). SERVER-ONLY.
# Do NOT prefix with NEXT_PUBLIC -- that would leak it to the browser.
# If unset, /api/ask returns a retrieval-only grounded answer (offline).
GROQ_API_KEY=

# Groq chat model. Defaults to llama-3.3-70b-versatile when unset.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: route the Groq call through an HTTPS proxy in local dev
# (e.g. behind a corporate proxy). Not needed on Vercel. Example:
# HTTPS_PROXY=http://user:pass@proxy.example.com:8080
HTTPS_PROXY=

# Optional: webhook the contact form (/api/contact) forwards submissions to
# (e.g. a Slack/Discord/Zapier incoming webhook). If unset, the form still
# succeeds and the UI offers a mailto: fallback.
CONTACT_WEBHOOK_URL=
